NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opção 1 (recomendada para deploy): chave pública RSA em Base64 (sem quebras de linha)
TRIAGE_RSA_PUBLIC_KEY_PEM_BASE64=

# Opção 2: chave pública PEM direta (com \n escapado)
TRIAGE_RSA_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Chave privada RSA da triagem (somente secret de servidor; não publicar)
TRIAGE_RSA_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=agende-sua-cirurgia
JWT_SECRET=troque-por-um-segredo-forte

GCP_PROJECT_ID=seu-projeto-gcp
GCS_BUCKET_NAME=asc-exames-criptografados
GOOGLE_CLOUD_CLIENT_EMAIL=
GOOGLE_CLOUD_PRIVATE_KEY=

BOOTSTRAP_DOCTOR_NOME=Medico Responsavel
BOOTSTRAP_DOCTOR_EMAIL=pstohler@gmail.com
BOOTSTRAP_DOCTOR_PASSWORD=freedoom
